@prefix bgg: <https://raw.githubusercontent.com/susvej/bg_ontology/refs/heads/main/bgg_march2025.ttl#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix svj: <https://vejdemo.se/boardgames#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

bgg:boardgame-ontology
    rdf:type owl:Ontology ;
    dcterms:description "This ontology uses the board games in the board game geek webpage, as available in Kaggle in 2024. It also allows tracking of owners of boardgames, and their ratings (as opposed to the aggregate bgg ratings) of the board games, to enable capture of personalized data." ;
    dcterms:title "BGG Board Game Ontology" ;
    skos:editorialNote """Future projects:
- Comments Galore: Add rdfs:comment to all classes except Category and Mechanic instances.
- More Data: Find an updated BGG dataset with post-2018 games."""@en .

# =============================================================================
# T-BOX: Schema
# =============================================================================

# --- Classes ---

bgg:Category
    rdf:type owl:Class ;
    rdfs:label "Category"@en ;
    rdfs:comment "A thematic grouping for board games as defined by BoardGameGeek (e.g. Fantasy, Economic, Card Game)."@en .

bgg:Creator
    rdf:type owl:Class ;
    rdfs:label "Creator"@en ;
    rdfs:comment "A person who designed or created a board game."@en .

bgg:Game
    rdf:type owl:Class ;
    rdfs:label "Game"@en ;
    rdfs:comment "A board game listed on BoardGameGeek, carrying descriptive properties such as name, player count, play time, and aggregate community ratings."@en .

bgg:Mechanic
    rdf:type owl:Class ;
    rdfs:label "Mechanic"@en ;
    rdfs:comment "A game-play mechanism or rule pattern as defined by BoardGameGeek (e.g. Auction/Bidding, Worker Placement, Dice Rolling)."@en .

bgg:MentalLoad
    rdf:type owl:Class ;
    rdfs:label "Mental Load"@en ;
    rdfs:comment "An ordered enumeration of perceived cognitive difficulty: easy, moderate, or difficult."@en .

bgg:Player
    rdf:type owl:Class ;
    rdfs:label "Player"@en ;
    rdfs:comment "A person who plays board games; may own games and record personal opinions on them."@en .

bgg:PlayerOpinion
    rdf:type owl:Class ;
    rdfs:label "Player Opinion"@en ;
    rdfs:comment "Represents a specific player's perspective on a specific game, carrying subjective properties such as perceived difficulty and personal rating."@en .

bgg:Size
    rdf:type owl:Class ;
    rdfs:label "Size"@en ;
    rdfs:comment "A physical size category for a game box (e.g. small, medium, large)."@en .

# --- Object Properties ---

bgg:hasCategory
    rdf:type owl:ObjectProperty ;
    rdfs:label "has category"@en ;
    rdfs:comment "Links a game to one of its BoardGameGeek thematic categories."@en ;
    rdfs:domain bgg:Game ;
    rdfs:range bgg:Category .

bgg:hasCreator
    rdf:type owl:ObjectProperty ;
    rdfs:label "has creator"@en ;
    rdfs:comment "Links a game to a person who designed or otherwise created it."@en ;
    rdfs:domain bgg:Game ;
    rdfs:range bgg:Creator .

bgg:hasMechanic
    rdf:type owl:ObjectProperty ;
    rdfs:label "has mechanic"@en ;
    rdfs:comment "Links a game to one of its BoardGameGeek game-play mechanics."@en ;
    rdfs:domain bgg:Game ;
    rdfs:range bgg:Mechanic .

bgg:hasMentalLoad
    rdf:type owl:ObjectProperty ;
    rdfs:label "has mental load"@en ;
    rdfs:comment "Links a player opinion to the perceived cognitive difficulty of the game."@en ;
    rdfs:domain bgg:PlayerOpinion ;
    rdfs:range bgg:MentalLoad .

bgg:hasOpinionHolder
    rdf:type owl:ObjectProperty ;
    rdfs:label "has opinion holder"@en ;
    rdfs:comment "Links a PlayerOpinion to the player who holds that opinion."@en ;
    rdfs:domain bgg:PlayerOpinion ;
    rdfs:range bgg:Player .

bgg:hasOpinionOf
    rdf:type owl:ObjectProperty ;
    rdfs:label "has opinion of"@en ;
    rdfs:comment "Links a PlayerOpinion to the game being evaluated."@en ;
    rdfs:domain bgg:PlayerOpinion ;
    rdfs:range bgg:Game .

bgg:hasOwnershipOf
    rdf:type owl:ObjectProperty ;
    rdfs:label "has ownership of"@en ;
    rdfs:comment "Links a player to a game they own."@en ;
    rdfs:domain bgg:Player ;
    rdfs:range bgg:Game .

bgg:hasSize
    rdf:type owl:ObjectProperty ;
    rdfs:label "has size"@en ;
    rdfs:comment "Links a game to its physical box size category."@en ;
    rdfs:domain bgg:Game ;
    rdfs:range bgg:Size .

bgg:hasURL
    rdf:type owl:ObjectProperty ;
    rdfs:label "has URL"@en ;
    rdfs:comment "The BoardGameGeek web page URL for this game."@en ;
    rdfs:domain bgg:Game .

bgg:isCategoryOf
    rdf:type owl:ObjectProperty ;
    rdfs:label "is category of"@en ;
    rdfs:comment "Inverse of bgg:hasCategory; links a category to the games in that category."@en ;
    rdf:inverseOf bgg:hasCategory ;
    rdfs:domain bgg:Category ;
    rdfs:range bgg:Game .

bgg:isMechanicOf
    rdf:type owl:ObjectProperty ;
    rdfs:label "is mechanic of"@en ;
    rdfs:comment "Inverse of bgg:hasMechanic; links a mechanic to the games that use it."@en ;
    rdf:inverseOf bgg:hasMechanic ;
    rdfs:domain bgg:Mechanic ;
    rdfs:range bgg:Game .

bgg:isOwnedBy
    rdf:type owl:ObjectProperty ;
    rdfs:label "is owned by"@en ;
    rdfs:comment "Inverse of bgg:hasOwnershipOf; links a game to a player who owns it."@en ;
    rdfs:domain bgg:Game ;
    rdfs:range bgg:Player .

bgg:likesCategory
    rdf:type owl:ObjectProperty ;
    rdfs:label "likes category"@en ;
    rdfs:comment "Links a player to a thematic category they enjoy."@en ;
    rdfs:domain bgg:Player ;
    rdfs:range bgg:Category .

bgg:likesMechanic
    rdf:type owl:ObjectProperty ;
    rdfs:label "likes mechanic"@en ;
    rdfs:comment "Links a player to a game-play mechanic they enjoy."@en ;
    rdfs:domain bgg:Player ;
    rdfs:range bgg:Mechanic .

# --- Datatype Properties ---

bgg:hasBestNumPlayers
    rdf:type owl:DatatypeProperty ;
    rdfs:label "has best number of players"@en ;
    rdfs:comment "The number of players at which the game plays best, according to BoardGameGeek community votes."@en ;
    rdfs:domain bgg:Game ;
    rdfs:range xsd:int .

bgg:hasComment
    rdf:type owl:DatatypeProperty ;
    rdfs:label "has comment"@en ;
    rdfs:comment "A free-text comment written by the player."@en ;
    rdfs:domain bgg:Player ;
    rdfs:range xsd:string .

bgg:hasGeekRating
    rdf:type owl:DatatypeProperty ;
    rdfs:label "has Geek Rating"@en ;
    rdfs:comment "The Geek Rating assigned by BoardGameGeek, computed from community votes and adjusted for vote count."@en ;
    rdfs:domain bgg:Game ;
    rdfs:range xsd:double .

bgg:hasID
    rdf:type owl:DatatypeProperty ;
    rdfs:label "has ID"@en ;
    rdfs:comment "The unique numeric identifier for the game on BoardGameGeek."@en ;
    rdfs:domain bgg:Game ;
    rdfs:range xsd:int .

bgg:hasMaxGameTime
    rdf:type owl:DatatypeProperty ;
    rdfs:label "has max game time"@en ;
    rdfs:comment "The maximum play time in minutes as listed on BoardGameGeek."@en ;
    rdfs:domain bgg:Game ;
    rdfs:range xsd:int .

bgg:hasMaxPlayers
    rdf:type owl:DatatypeProperty ;
    rdfs:label "has max players"@en ;
    rdfs:comment "The maximum number of players the game supports."@en ;
    rdfs:domain bgg:Game ;
    rdfs:range xsd:int .

bgg:hasMaxRecAge
    rdf:type owl:DatatypeProperty ;
    rdfs:label "has max recommended age"@en ;
    rdfs:comment "The maximum recommended player age in years."@en ;
    rdfs:domain bgg:Game ;
    rdfs:range xsd:int .

bgg:hasMinGameTime
    rdf:type owl:DatatypeProperty ;
    rdfs:label "has min game time"@en ;
    rdfs:comment "The minimum play time in minutes as listed on BoardGameGeek."@en ;
    rdfs:domain bgg:Game ;
    rdfs:range xsd:int .

bgg:hasMinPlayers
    rdf:type owl:DatatypeProperty ;
    rdfs:label "has min players"@en ;
    rdfs:comment "The minimum number of players required to play the game."@en ;
    rdfs:domain bgg:Game ;
    rdfs:range xsd:int .

bgg:hasMinRecAge
    rdf:type owl:DatatypeProperty ;
    rdfs:label "has min recommended age"@en ;
    rdfs:comment "The minimum recommended player age in years."@en ;
    rdfs:domain bgg:Game ;
    rdfs:range xsd:int .

bgg:hasName
    rdf:type owl:DatatypeProperty ;
    rdfs:label "has name"@en ;
    rdfs:comment "The name of the game as listed on BoardGameGeek."@en ;
    rdfs:domain bgg:Game ;
    rdfs:range xsd:string .

bgg:hasPlayerRatingOpinion
    rdf:type owl:DatatypeProperty ;
    rdfs:label "has player rating opinion"@en ;
    rdfs:comment "A personal rating of the game by the opinion holder, on a scale of 1 to 10."@en ;
    rdfs:domain bgg:PlayerOpinion ;
    rdfs:range xsd:decimal .

bgg:hasPublisher
    rdf:type owl:DatatypeProperty ;
    rdfs:label "has publisher"@en ;
    rdfs:comment "The name of the game's publisher."@en ;
    rdfs:domain bgg:Game ;
    rdfs:range xsd:string .

bgg:hasRating
    rdf:type owl:DatatypeProperty ;
    rdfs:label "has rating"@en ;
    rdfs:comment "The average community rating on BoardGameGeek, on a scale of 1 to 10."@en ;
    rdfs:domain bgg:Game ;
    rdfs:range xsd:double .

