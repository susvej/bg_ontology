# =============================================================================
# SHACL Constraints
# =============================================================================


bgg:SizeConstraint a sh:NodeShape ;
    sh:property [ sh:in ( bgg:small bgg:medium bgg:large ) ;
            sh:path bgg:hasSize ] ;
    sh:targetClass bgg:Game .

bgg:UniqueIDConstraint a sh:PropertyShape ;
    sh:datatype xsd:int ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:path bgg:hasID ;
    sh:unique true .

bgg:UniqueURLConstraint a sh:PropertyShape ;
    sh:maxCount 1 ;
    sh:message "Value must be a valid URL." ;
    sh:minCount 1 ;
    sh:path bgg:hasURL ;
    sh:pattern "^(https?://[a-zA-Z0-9.-]+\\.[a-zA-Z]{2,})?$" ;
    sh:unique true .

bgg:hasCategory sh:minCount 1 .

bgg:hasComment sh:maxCount 1 ;
    sh:minCount 1 .

bgg:hasGeekRating sh:maxCount 1 ;
    sh:minCount 1 .

bgg:hasMaxGameTime sh:maxCount 1 ;
    sh:minCount 1 .

bgg:hasMaxPlayers sh:maxCount 1 ;
    sh:minCount 1 .

bgg:hasMaxRecAge sh:maxCount 1 ;
    sh:minCount 0 .

bgg:hasMechanic sh:minCount 1 .

bgg:hasMentalLoad sh:in ( bgg:easy bgg:moderate bgg:difficult ) ;
    sh:maxCount 1 ;
    sh:minCount 0 .

bgg:hasMinGameTime sh:maxCount 1 ;
    sh:minCount 1 .

bgg:hasMinPlayers sh:maxCount 1 ;
    sh:minCount 1 .

bgg:hasMinRecAge sh:maxCount 1 ;
    sh:minCount 0 .

bgg:hasPlayerRatingOpinion sh:maxInclusive 10.0 ;
    sh:minInclusive 1.0 .

bgg:hasPublisher sh:maxCount 1 ;
    sh:minCount 1 .

bgg:hasRating sh:maxCount 1 ;
    sh:minCount 1 .

bgg:hasSize sh:maxCount 1 ;
    sh:minCount 1 .


